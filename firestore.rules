rules_version = '2';

// Casa Celeste — regole di sicurezza Firestore.
// rooms: chiunque può leggere (per mostrare lo stato delle stanze sul sito pubblico),
//        solo il proprietario autenticato (dashboard) può modificare.
// bookings: chiunque può CREARE una prenotazione (dal modulo del sito),
//           ma solo il proprietario autenticato può leggerle, aggiornarle o cancellarle.
service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{roomId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /commons/{commonId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /monoSlides/{slideId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /bookings/{bookingId} {
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() < 200
                    && request.resource.data.email is string
                    && request.resource.data.email.size() > 0
                    && request.resource.data.email.size() < 200
                    && request.resource.data.roomLabel is string
                    && request.resource.data.status == 'nuovo';
      allow read, update, delete: if request.auth != null;
    }

    // ======================================================================
    // Affittacamere (locazione turistica breve termine) — stesso progetto
    // Firebase, collezioni separate con prefisso tourism_. Vedi
    // affittacamere/js/firebase-init.js e functions/index.js.
    // ======================================================================

    match /tourism_rooms/{roomId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /tourism_commons/{commonId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /tourism_monoSlides/{slideId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /tourism_reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /tourism_settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // La creazione di una prenotazione passa SOLO dalla Cloud Function
    // createBooking (transazione anti-doppia-prenotazione + validazione
    // completa, vedi functions/index.js): l'Admin SDK che usa bypassa
    // comunque queste regole, quindi qui il client pubblico non può mai
    // scrivere direttamente — evita di aggirare la transazione.
    match /tourism_bookings/{bookingId} {
      allow create: if false;
      allow read, update, delete: if request.auth != null;
    }

    // Messaggi lasciati dal widget di assistenza — la scrittura passa SOLO
    // dalla Cloud Function submitAssistMessage (validazione completa lato
    // server, l'Admin SDK bypassa comunque queste regole); la dashboard
    // (proprietario autenticato) legge/aggiorna/cancella direttamente.
    match /tourism_assistMessages/{messageId} {
      allow create: if false;
      allow read, update, delete: if request.auth != null;
    }

    // Documenti d'identità degli ospiti — dati sensibili, MAI leggibili né
    // scrivibili dal client pubblico: la scrittura passa solo dalla Cloud
    // Function submitGuestDocuments (verifica token + validazione completa
    // lato server, l'Admin SDK bypassa queste regole).
    match /tourism_guestDocuments/{bookingId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Ospiti già identificati in un soggiorno precedente (chiave hash, mai
    // il documento in chiaro) — riconosciuti in automatico dalla Cloud
    // Function submitGuestDocuments/markIdentityVerified, mai scritti dal
    // client direttamente.
    match /tourism_verifiedGuests/{guestKey} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Sessioni del wizard bot Telegram (functions/telegram-bot.js) — solo
    // l'Admin SDK della Cloud Function le scrive (bypassa comunque queste
    // regole); dichiarate qui solo per coerenza/difesa in profondità, come
    // tourism_guestDocuments/tourism_verifiedGuests sopra.
    match /tourism_botSessions/{chatId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
